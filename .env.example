# Copy this file to `.env` and fill in real values.
# .env is gitignored — never commit secrets.

# === Required ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxx

# === Optional ===
# 預設模型：面試用 sonnet，debug 用 haiku 省成本
BRIDGE_MODEL=claude-sonnet-4-5
BRIDGE_MODEL_CHEAP=claude-haiku-4-5

# SQLite 路徑 — 本機開發可用 data/bridge.sqlite；
# 在 FUSE 掛載環境下走 /tmp 以避免檔案鎖問題（跟 district-analyst 同策略）
BRIDGE_DB_PATH=data/bridge.sqlite

# 爬蟲速率限制（秒 / request）
SCRAPER_DELAY=1.5

# 是否跳過 LLM 實際呼叫（dry-run 模式；CI / 沒網路時用）
BRIDGE_DRY_RUN=0
